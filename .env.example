# ============================================================================
# ANTHROPIC API CONFIGURATION (REQUIRED)
# ============================================================================
# This is needed for the LLM-powered ingestion and querying features.
#
# How to get your API key:
#   1. Go to: https://console.anthropic.com/
#   2. Sign up or log in with your account
#   3. Click "API Keys" in the left sidebar
#   4. Click "Create Key" button
#   5. Copy the generated key (starts with "sk-ant-")
#   6. Paste it below (keep it secret!)
#
# Cost: Pay-as-you-go, roughly:
#   - Ingestion: $0.003-0.015 per 1K tokens (depends on source size)
#   - Queries: $0.003-0.015 per 1K tokens (depends on query complexity)
#   - Budget: ~$1-5/month for typical personal use
#
# Documentation: https://docs.anthropic.com/
#
ANTHROPIC_API_KEY=sk-ant-your-actual-api-key-here


# ============================================================================
# NOTION INTEGRATION (OPTIONAL)
# ============================================================================
# Only needed if you want to sync your Notion technology watch database.
# If you don't use Notion, leave these blank or commented out.

# NOTION_API_KEY: Authentication token for Notion API
#
# How to get it:
#   1. Go to: https://www.notion.so/my-integrations
#   2. Click "Create new integration"
#   3. Name it: "Wiki RAG System"
#   4. Accept the terms and click "Create integration"
#   5. Copy the "Internal Integration Token" (starts with "ntn_")
#   6. Paste it below
#
# Note: This token has access to any databases you share with it.
# Keep it secret!
#
NOTION_API_KEY=ntn_your-actual-notion-token-here

# NOTION_DATABASE_ID: The ID of your technology watch database
#
# How to find it:
#   1. Open your technology watch database in Notion
#   2. Look at the URL in your browser:
#      https://notion.so/user/[THIS_IS_YOUR_DATABASE_ID]?v=...
#                              ^^^^^^^^^^^^^^^^^^^^^^^^
#   3. Copy everything between "user/" and the first "?"
#   4. Paste it below (it's a long string of alphanumeric characters)
#
# To use this integration:
#   1. Open your Notion database
#   2. Click the three dots (...) in the top-right
#   3. Select "Connections"
#   4. Find your integration and click to connect it
#   5. Now the system can read your technology watch items
#
# Database should have columns:
#   - Name (Title) - Item name
#   - Description (Rich Text) - What it is
#   - Category (Select) - Framework, Tool, Library, etc.
#   - URL (URL) - Link to resource
#   - Date Discovered (Date) - When found
#   - Status (Select) - New, Evaluating, Adopted, etc.
#
NOTION_DATABASE_ID=your-database-id-here


# ============================================================================
# JIRA INTEGRATION (OPTIONAL)
# ============================================================================
# Only needed if you want to sync JIRA tickets to a vault.
# Requires config/sources.yaml to define a "jira" source and
# config/vaults.yaml to define a vault binding for it.

# JIRA_HOST: Your JIRA instance URL (e.g. https://yourcompany.atlassian.net)
JIRA_HOST=

# JIRA_USERNAME: Your JIRA account email
JIRA_USERNAME=

# JIRA_API_TOKEN: JIRA API token (not your password)
# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=


# ============================================================================
# CONFLUENCE INTEGRATION (OPTIONAL)
# ============================================================================
# Only needed if you want to sync Confluence pages to a vault.
# Requires config/sources.yaml to define a "confluence" source and
# config/vaults.yaml to define a vault binding for it.

# CONFLUENCE_HOST: Your Confluence instance URL (e.g. https://yourcompany.atlassian.net)
CONFLUENCE_HOST=

# CONFLUENCE_USERNAME: Your Confluence account email
CONFLUENCE_USERNAME=

# CONFLUENCE_API_TOKEN: Same Atlassian API token as JIRA (if same instance)
CONFLUENCE_API_TOKEN=


# ============================================================================
# SYSTEM CONFIGURATION
# ============================================================================

# DEBUG: Set to true for verbose output and development mode
#   false = Production mode (cleaner logs)
#   true = Development mode (detailed diagnostics)
DEBUG=false

# LOG_LEVEL: Verbosity of logging output
#   OPTIONS: DEBUG, INFO, WARNING, ERROR, CRITICAL
#   INFO = Recommended for normal use (shows important info)
#   DEBUG = Use when troubleshooting (very verbose)
#   WARNING = Only show warnings and errors
LOG_LEVEL=INFO


# ============================================================================
# QUICK SETUP CHECKLIST
# ============================================================================
# 1. Get Anthropic API key:
#    - Visit https://console.anthropic.com/
#    - Create API key, paste below (REQUIRED)
#
# 2. (Optional) Set up Notion integration:
#    - Visit https://www.notion.so/my-integrations
#    - Create integration, get token
#    - Share your database with the integration
#    - Find database ID in URL
#    - Paste both values below
#
# 3. Save this file as ".env" (remove .example)
#
# 4. Start the system:
#    $ docker compose up -d
#    $ open http://localhost:8080
#
# ============================================================================
